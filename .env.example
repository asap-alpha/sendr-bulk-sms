# Copy to .env and fill with real values.

# Base URL of the TailorsFlow backend API (no trailing slash), e.g. https://api.cheqam.com
VITE_API_BASE_URL=http://localhost:5071

# Firebase web-app config — MUST be the SAME Firebase project the backend verifies tokens
# against (Firebase console → Project settings → your web app). These are public config,
# not secrets.
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-firebase-auth-domain
VITE_FIREBASE_PROJECT_ID=your-firebase-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-firebase-storage-bucket
VITE_FIREBASE_MESSAGING_SENDER_ID=your-firebase-messaging-sender-id
VITE_FIREBASE_APP_ID=your-firebase-app-id

